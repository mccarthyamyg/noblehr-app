{
  "name": "policyvault-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:client": "npm run build --prefix \"../Handbook Policy App\"",
    "init-db": "node scripts/init-db.js",
    "backup": "node scripts/backup-db.js",
