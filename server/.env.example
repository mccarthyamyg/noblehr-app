# Copy to .env and set values
PORT=3001
NODE_ENV=development

# --- REQUIRED in production (server exits if unset) ---
JWT_SECRET=your-secret-at-least-32-chars

# --- Production / hosting ---
# App URL (for email links: approval, reset password, verify). Launch/invite APIs also use this when it is a public URL;
# if unset or left as localhost while the app is behind Railway/proxy, the server derives https://host from the request.
FRONTEND_URL=http://localhost:5173
# Comma-separated allowed CORS origins. In production set to FRONTEND_URL or add multiple (e.g. https://app.example.com,https://admin.example.com)
CORS_ORIGINS=
# If the SPA is on a different host than this API (e.g. Vercel + Railway), set: AUTH_COOKIE_SAMESITE=none
# (cookies are always Secure in production). Same host = omit or strict.
# AUTH_COOKIE_SAMESITE=none

# --- Optional: Google Sign-In (Google Cloud Console) ---
GOOGLE_CLIENT_ID=

# --- Super admin seed & tests ---
# Used by: npm run seed-super-admin, test-e2e, test-smoke (password 8+ chars).
# Email defaults to legacy address if unset; set SUPER_ADMIN_EMAIL to your production super admin.
# Production: set BOTH. Without SUPER_ADMIN_EMAIL, boot sync is skipped (we do not guess the legacy test email in prod).
# If both SUPER_ADMIN_EMAIL and SUPER_ADMIN_PASSWORD (8+ chars) are set, the server applies them on startup (no extra flag).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
# Optional legacy (local dev): AUTO_SEED_SUPER_ADMIN=true with password only uses the dev default email when SUPER_ADMIN_EMAIL is unset.
# AUTO_SEED_SUPER_ADMIN=true

# --- Transactional email (Resend API). When RESEND_API_KEY is unset, email is logged to console only. ---
# Get API key: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxx
# Optional From (must be allowed in Resend: verified domain or onboarding@resend.dev for testing)
# EMAIL_FROM=Noble HR <noreply@yourdomain.com>

# --- AI policy generation (optional; when unset, /ai/generate-policy returns 503) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Future: Postgres (not used yet; app uses SQLite at server/data/policyvault.db) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
