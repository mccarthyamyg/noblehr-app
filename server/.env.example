# Copy to .env and set values
PORT=3001
NODE_ENV=development

# --- REQUIRED in production (server exits if unset) ---
JWT_SECRET=your-secret-at-least-32-chars

# --- Production / hosting ---
# App URL (for invite links, reset password, launch links). In production set to https://yourdomain.com
FRONTEND_URL=http://localhost:5173
# Comma-separated allowed CORS origins. In production set to FRONTEND_URL or add multiple (e.g. https://app.example.com,https://admin.example.com)
CORS_ORIGINS=

# --- Optional: Google Sign-In (Google Cloud Console) ---
GOOGLE_CLIENT_ID=

# --- E2E/CI: super admin (run seed-super-admin.js first) ---
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# --- SMTP: approval notifications, password reset. When unset, logs to console. ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=PolicyVault <noreply@policyvault.app>

# --- AI policy generation (optional; when unset, /ai/generate-policy returns 503) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Future: Postgres (not used yet; app uses SQLite at server/data/policyvault.db) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
